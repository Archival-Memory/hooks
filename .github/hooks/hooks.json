{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "node scripts/context.js SessionStart",
        "cwd": ".github/hooks"
      }
    ],
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "node scripts/context.js UserPromptSubmit",
        "cwd": ".github/hooks"
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "command": "node scripts/update.js PreToolUse",
        "cwd": ".github/hooks"
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "node scripts/update.js Stop",
        "cwd": ".github/hooks"
      }
    ]
  }
}
