{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "node scripts/session-start.js",
        "cwd": ".github/hooks"
      }
    ],
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "node scripts/user-prompt-submit.js",
        "cwd": ".github/hooks"
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "command": "node scripts/post-response.js",
        "cwd": ".github/hooks"
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "node scripts/post-response.js",
        "cwd": ".github/hooks"
      }
    ]
  }
}
